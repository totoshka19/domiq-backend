# --- Локальная разработка ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/domiq

# --- Продакшн: Neon ---
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/domiq?sslmode=require

# --- Локальный Redis (dev) ---
REDIS_URL=redis://localhost:6379

# --- Продакшн: Upstash Redis (обязательно rediss:// с двумя s) ---
# REDIS_URL=rediss://default:pass@xxx.upstash.io:6379

# JWT
SECRET_KEY=change-me-to-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Файловое хранилище (S3-совместимый API)
# Используется Supabase Storage, но подойдёт любое S3-совместимое хранилище (Cloudflare R2, MinIO и др.)
S3_BUCKET_NAME=domiq-files
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_ENDPOINT_URL=https://your-project.supabase.co/storage/v1/s3
S3_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://domiq.vercel.app

# Email / SMTP (опционально — без этих настроек уведомления только логируются)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@domiq.ru
# ADMIN_EMAIL=admin@domiq.ru
